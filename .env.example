# Telegram Bot 配置
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHAT_IDS=-1001234567890,-1009876543210   # 多个群组/频道ID用逗号分隔，支持负数（超级群组）

# Webhook 安全（与 Pine Script 中的 webhookSecret 保持一致）
WEBHOOK_SECRET=your_super_secret_key_2026_qai

# Flask 配置
PORT=8080
DEBUG=false
TZ=Asia/Hong_Kong

# 可选：日志级别
LOG_LEVEL=INFO

# 可选：最大保留警报历史数量（仪表盘用）
MAX_ALERT_HISTORY=100